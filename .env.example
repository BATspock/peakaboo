# Copy this file to .env and fill in real values. .env is gitignored.

# Google Maps — single key works for Android, iOS, and Web in dev.
# Restrict it in Google Cloud Console: Maps SDK for Android, Maps SDK for iOS, Maps JavaScript API.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Supabase — create a project at https://supabase.com (free tier).
# Project Settings → API → copy these two values.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
